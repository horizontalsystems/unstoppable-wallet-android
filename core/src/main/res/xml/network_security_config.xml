<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />

    <!--
      Monero public nodes are commonly served over plain HTTP on ports 18081/18089.
      Cleartext is permitted only for the bundled default node domains so the in-app
      node ping (OkHttp) reaches them; wallet sync itself uses native sockets.
      Keep this list in sync with MoneroNodeManager.defaultNodesInitial.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">node.xmr.rocks</domain>
        <domain includeSubdomains="false">opennode.xmr-tw.org</domain>
        <domain includeSubdomains="false">node.sethforprivacy.com</domain>
        <domain includeSubdomains="false">nodex.monerujo.io</domain>
        <domain includeSubdomains="false">xmr-node.cakewallet.com</domain>
        <domain includeSubdomains="false">monero.stackwallet.com</domain>
    </domain-config>
</network-security-config>
